rules_version = '2';

// 植物生育管理アプリ用ルール。
// - 匿名認証でサインインしている (request.auth != null) 利用者のみ読み書き可能。
// - 書き込み時、ドキュメントのスキーマを軽くバリデーションする。
// - 1レコード = 1日分。doc id は YYYY-MM-DD 形式のみ許可。
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidDateId(id) {
      return id.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['date', 'strains', 'averages'])
        && data.date is string
        && data.strains is list
        && data.strains.size() > 0
        && data.strains.size() <= 50
        && data.averages is map;
    }

    match /classes/{classId}/records/{dateId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isValidDateId(dateId)
        && isValidRecord(request.resource.data);
      allow delete: if false; // 誤操作防止のため UI では削除させない
    }

    // それ以外は全拒否 (デフォルト)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
