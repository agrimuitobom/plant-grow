rules_version = '2';

// 植物生育管理アプリ用ルール。
// - Google ログイン (匿名以外) でサインインしている利用者のみ読み書き可能。
// - 書き込み時、ドキュメントのスキーマを軽くバリデーションする。
// - 1レコード = 1日分。doc id は YYYY-MM-DD 形式のみ許可。
// - 教員 (classes/{classId}/teachers/{uid}) は同じクラスの全生徒を読み取りできる。
//   教員ドキュメントは Firebase Console から手動で追加する運用。
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isValidDateId(id) {
      return id.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['date', 'strains', 'averages'])
        && data.date is string
        && data.strains is list
        && data.strains.size() > 0
        && data.strains.size() <= 50
        && data.averages is map;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasAuditFields(data, userId) {
      return data.createdBy == userId
        && data.updatedBy == userId;
    }

    // 教員ロールの判定。exists() は Rules を再帰的に評価しないので O(1)。
    function isTeacher(classId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/classes/$(classId)/teachers/$(request.auth.uid));
    }

    // 教員ドキュメント。
    // - 最初の 1 人は Firebase Console から手動で seed する必要がある (chicken-and-egg)。
    // - 一度教員ができれば、その教員が他のユーザを教員に昇格・解除できる。
    // - 自分自身を解除する操作は禁止 (誤操作で全教員不在を防ぐ)。
    // - 任意のサインイン済みユーザに read を許可しているのは、自分が教員か検出するため。
    match /classes/{classId}/teachers/{teacherId} {
      allow read: if isSignedIn();
      allow create: if isTeacher(classId)
        && request.resource.data.uid == teacherId
        && request.resource.data.keys().hasAll(['uid', 'displayName']);
      allow delete: if isTeacher(classId) && request.auth.uid != teacherId;
      allow update: if false;
    }

    // クラス名簿。生徒は自分のエントリだけ upsert でき、
    // 同じクラスの教員は全員分を一覧できる。
    match /classes/{classId}/students/{userId} {
      allow read: if isOwner(userId) || isTeacher(classId);
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'displayName']);
      allow delete: if false;
    }

    // 各生徒は自分の領域だけ R/W 可能。教員は read だけ可能 (書き込みは本人限定)。
    // 監査用に createdBy / updatedBy を記録する (パスの uid と一致を強制)。
    match /classes/{classId}/students/{userId}/records/{dateId} {
      allow read: if isOwner(userId) || isTeacher(classId);
      allow create, update: if isOwner(userId)
        && isValidDateId(dateId)
        && isValidRecord(request.resource.data)
        && hasAuditFields(request.resource.data, userId);
      allow delete: if false; // 誤操作防止のため UI では削除させない
    }

    // それ以外は全拒否 (デフォルト)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
