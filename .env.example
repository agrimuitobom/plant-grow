# ローカル開発用。このファイルをコピーして .env.local を作成し、実際の値を入れてください。
# cp .env.example .env.local

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 任意。省略時は "class-demo"
VITE_CLASS_ID=class-demo

# 任意。校内利用に限定したい場合は許可ドメインをカンマ区切りで指定。
# 例: VITE_ALLOWED_EMAIL_DOMAINS=example-school.ac.jp,example-school.jp
# 設定すると、許可ドメイン以外のメールでログインしたユーザは即サインアウトされる。
VITE_ALLOWED_EMAIL_DOMAINS=
